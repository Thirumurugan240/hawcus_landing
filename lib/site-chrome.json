rrentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z\"/><path d=\"M8 12v2M12 9v5M16 11v3\"/></svg></span>\n                  <span class=\"mega__text\"><b>WhatsApp CRM</b><span>Manage your entire sales workflow directly on WhatsApp.</span></span>\n                </a>\n                <a class=\"mega__item\" role=\"menuitem\" href=\"/features/smart-triggers/\">\n                  <span class=\"mega__icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M13 2L3 14h9l-1 8 10-12h-9l1-8z\"/></svg></span>\n                  <span class=\"mega__text\"><b>Smart Triggers</b><span>Trigger messages and workflows based on user actions.</span></span>\n                </a>\n                <a class=\"mega__item\" role=\"menuitem\" href=\"/features/dialer-app/\">\n                  <span class=\"mega__icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M22 16.9v3a2 2 0 01-2.2 2 19.8 19.8 0 01-8.6-3.1 19.5 19.5 0 01-6-6A19.8 19.8 0 012.1 4.2 2 2 0 014.1 2h3a2 2 0 012 1.7c.1.9.4 1.8.7 2.7a2 2 0 01-.5 2.1L8.1 9.9a16 16 0 006 6l1.4-1.2a2 2 0 012.1-.5c.9.3 1.8.6 2.7.7a2 2 0 011.7 2z\"/></svg></span>\n                  <span class=\"mega__text\"><b>Dialer App</b><span>Call, record and manage every lead from your phone.</span></span>\n                </a>\n              </div>\n            </div>\n          </li>\n          <li><a href=\"/pricing.html\">Pricing</a></li>\n          <li><a href=\"/blog/\">Blog</a></li>\n          <li><a href=\"/#faq\">FAQ</a></li>\n        </ul>\n        <div class=\"nav__actions\">\n          <a class=\"btn btn--ghost\" href=\"https://app.hawcus.com\">Sign in</a>\n          <a class=\"btn btn--solid\" href=\"/book-a-demo.html\">Book a Demo</a>\n          <button class=\"nav__toggle\" aria-label=\"Toggle menu\" aria-expanded=\"false\" aria-controls=\"primary-menu\">\n            <span></span><span></span><span></span>\n          </button>\n        </div>\n      </nav>\n    </div>\n  </header>", "tail": "  <footer class=\"site-footer\">\n    <div class=\"container\">\n      <div class=\"footer__grid\">\n        <div class=\"footer__brand\">\n          <img src=\"/hawcus-logo-white.png\" alt=\"Hawcus CRM logo\" width=\"95\" height=\"40\" />\n          <p>The WhatsApp-first CRM that turns every lead into a conversation, and every conversation into a customer.</p>\n        </div>\n        <div class=\"footer__col\">\n          <h4>Product</h4>\n          <ul>\n            <li><a href=\"/#features\">Features</a></li>\n            <li><a href=\"/#how\">How it works</a></li>\n            <li><a href=\"/pricing.html\">Pricing</a></li>\n            <li><a href=\"https://app.hawcus.com\">Sign in</a></li>\n          </ul>\n        </div>\n        <div class=\"footer__col\">\n          <h4>Resources</h4>\n          <ul>\n            <li><a href=\"/blog/\">Blog</a></li>\n            <li><a href=\"/#faq\">FAQ</a></li>\n            <li><a href=\"/#contact\">Get a demo</a></li>\n          </ul>\n        </div>\n        <div class=\"footer__col\">\n          <h4>Company</h4>\n          <ul>\n            <li><a href=\"#\">About</a></li>\n            <li><a href=\"/#contact\">Contact</a></li>\n            <li><a href=\"/privacy.html\">Privacy</a></li>\n            <li><a href=\"/terms.html\">Terms</a></li>\n          </ul>\n        </div>\n      </div>\n      <div class=\"footer__bottom\">\n        <span>\u00a9 <span data-year>2026</span> Hawcus CRM. All rights reserved.</span>\n        <div class=\"footer__social\">\n          <a href=\"https://www.facebook.com/profile.php?id=61591799066978\" aria-label=\"Hawcus on Facebook\" target=\"_blank\" rel=\"noopener\"><svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M22 12a10 10 0 1 0-11.6 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5h-1.3c-1.2 0-1.6.8-1.6 1.6V12h2.8l-.4 2.9h-2.4v7A10 10 0 0 0 22 12z\"/></svg></a>\n          <a href=\"https://www.instagram.com/hawcuscrm/\" aria-label=\"Hawcus on Instagram\" target=\"_blank\" rel=\"noopener\"><svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M12 2.2c3.2 0 3.6 0 4.9.1 1.2.1 1.8.2 2.2.4.6.2 1 .5 1.4.9.4.4.7.8.9 1.4.2.4.4 1 .4 2.2.1 1.3.1 1.7.1 4.9s0 3.6-.1 4.9c-.1 1.2-.2 1.8-.4 2.2-.2.6-.5 1-.9 1.4-.4.4-.8.7-1.4.9-.4.2-1 .4-2.2.4-1.3.1-1.7.1-4.9.1s-3.6 0-4.9-.1c-1.2-.1-1.8-.2-2.2-.4a3.9 3.9 0 0 1-1.4-.9 3.9 3.9 0 0 1-.9-1.4c-.2-.4-.4-1-.4-2.2C2.2 15.6 2.2 15.2 2.2 12s0-3.6.1-4.9c.1-1.2.2-1.8.4-2.2.2-.6.5-1 .9-1.4.4-.4.8-.7 1.4-.9.4-.2 1-.4 2.2-.4 1.3-.1 1.7-.1 4.8-.1zm0 3.2A6.6 6.6 0 1 0 18.6 12 6.6 6.6 0 0 0 12 5.4zm0 10.9A4.3 4.3 0 1 1 16.3 12 4.3 4.3 0 0 1 12 16.3zm6.9-11.1a1.6 1.6 0 1 1-1.6-1.5 1.6 1.6 0 0 1 1.6 1.5z\"/></svg></a>\n        </div>\n      </div>\n    </div>\n  </footer>\n\n  <!-- Timed lead-nurturing popup -->\n  <div class=\"popup\" id=\"nurture-popup\" hidden aria-hidden=\"true\">\n    <div class=\"popup__backdrop\" data-popup-close></div>\n    <div class=\"popup__card\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"popup-title\">\n      <button class=\"popup__close\" type=\"button\" aria-label=\"Close\" data-popup-close>\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\"><path d=\"M6 6l12 12M18 6L6 18\"/></svg>\n      </button>\n\n      <div class=\"popup__copy\">\n        <span class=\"popup__eyebrow\">Lead Nurturing</span>\n        <h2 class=\"popup__title\" id=\"popup-title\">Turn Silent Leads Into <span class=\"hl-ink\">Conversations</span></h2>\n        <p class=\"popup__sub\">Automatically re-engage inactive leads with personalised WhatsApp messages, reminders, and nurturing sequences.</p>\n        <a class=\"btn btn--primary btn--lg popup__cta\" href=\"/book-a-demo.html\" data-popup-close>Book A Demo\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M5 12h14M13 6l6 6-6 6\"/></svg>\n        </a>\n        <p class=\"popup__note\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20 6L9 17l-5-5\"/></svg>\n          Stay connected with every lead, automatically.\n        </p>\n      </div>\n\n      <div class=\"popup__visual\" aria-hidden=\"true\">\n        <div class=\"pchat\">\n          <div class=\"pchat__bub pchat__bub--out\">Hi Rohan, great speaking with you today. Here is a quick guide to our <b>exclusive travel packages for Singapore</b>. Let me know if you have questions.</div>\n          <div class=\"pchat__bub pchat__bub--in\">Any special deals for families?</div>\n          <div class=\"pchat__bub pchat__bub--out\">Yes, we have family packages with group discounts, kids activities, and upgraded stays. Happy to share the details.</div>\n          <div class=\"pchat__bub pchat__bub--in\">Okay, great!</div>\n          <div class=\"pchat__bub pchat__bub--out\">Did you know our <b>Travel Planner</b> handles flights, hotels, and curated local experiences in one place? Shall I walk you through it?</div>\n        </div>\n        <div class=\"ppanel\">\n          <div class=\"ppanel__tabs\"><span class=\"is-on\"></span><span></span><span></span><span></span></div>\n          <div class=\"ppanel__row\">\n            <span>Auto Follow-Ups</span>\n            <i class=\"ppanel__toggle\"></i>\n          </div>\n          <div class=\"ppanel__row ppanel__row--stack\">\n            <small>Lead Status</small>\n            <b>Excited for Singapore</b>\n          </div>\n          <div class=\"ppanel__row ppanel__row--stack\">\n            <small>Next Message</small>\n            <b>Singapore Package</b>\n            <em>07 Jul, 18:00</em>\n          </div>\n          <div class=\"ppanel__row ppanel__row--stack\">\n            <small>Active Sequence</small>\n            <div class=\"ppanel__select\">Singapore <span>6 messages</span></div>\n          </div>\n          <div class=\"ppanel__hist\">\n            <div class=\"ppanel__histhead\"><span>Date</span><span>Message</span><span>Sent</span></div>\n            <div class=\"ppanel__histrow\"><span>31 Jun</span><span>Welcome Message</span><span>Automatic</span></div>\n            <div class=\"ppanel__histrow\"><span>04 Jul</span><span>Package Details</span><span>Automatic</span></div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <script src=\"/js/main.js\" defer></script>\n</body>\n</html>"}